---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import ProjectCard from '@/components/ProjectCard.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllProjects } from '@/lib/data-utils'

const projects = await getAllProjects()
---

<Layout class="max-w-3xl">
  <PageHead slot="head" title="About" />
  <Breadcrumbs items={[{ label: 'About', icon: 'lucide:info' }]} />

  <section>
    <div class="min-w-full">
      <div class="prose mb-8 prose-neutral dark:prose-invert">
        <p class="mt-0">
          I’m <Link href="https://github.com/dogukannn" external underline>dogukannn</Link>. I’m a graphics/engine developer at a AA game studio, working on real-time rendering and engine-side features.
        </p>
        <p>
          I’ve shipped work on Unreal Engine/Vulkan interop projects in non-game VFX/broadcast pipelines, and I enjoy getting close to the metal-Vulkan and DirectX—when it helps performance or correctness.
        </p>
        <p>
          I’m especially interested in optimization, tooling, and systems-level problems: profiling, memory/CPU/GPU tradeoffs, multithreading, and making rendering pipelines more predictable.
        </p>
        <p>
          This site is where I keep notes and write-ups from experiments and side projects. If you want a starting point, the ray tracing series is a good overview:
          <Link href="/blog/ray-tracing-one" underline>Part 1</Link>
          and
          <Link href="/blog/2024-11-8-ray-tracing-two" underline>Part 2</Link>.
        </p>
      </div>

      <h2 class="mb-4 text-2xl font-medium">Projects</h2>
      <div class="flex flex-col gap-4">
        {projects.map((project) => <ProjectCard project={project} />)}
      </div>
    </div>
  </section>
</Layout>
